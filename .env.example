# Copy this file to ".env" in the same folder and fill in real values.
# .env is read by scripts/common.py — never commit the filled-in version.

# --- YouTube (Google Cloud Console -> APIs & Services -> YouTube Data API v3) ---
YOUTUBE_API_KEY=

# --- Reddit (self-serve app creation ended June 2026 under the Responsible
# Builder Policy; requires explicit approval first -- see README) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=commentary-tracker/0.1 by <your-reddit-username>

# --- X / Twitter (https://developer.x.com -> create project & app) ---
X_BEARER_TOKEN=
# Hard monthly cap on post reads, enforced client-side before each call
# (X bills $0.005/read -- default 500 reads =~ $2.50/mo). Usage is tracked
# in .x_usage.json at the repo root; check it anytime with
# `python scripts/twitter_fetch.py --usage`.
X_MONTHLY_READ_BUDGET=500

# --- Podcast transcription (optional; only needed if a feed has no published transcript) ---
OPENAI_API_KEY=
